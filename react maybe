    <script>
        // Smooth scrolling for navigation links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                
                const targetId = this.getAttribute('href');
                if(targetId === '#') return;
                
                const targetElement = document.querySelector(targetId);
                if(targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop - 80,
                        behavior: 'smooth'
                    });
                }
            });
        });
        
        // Form submission
        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Köszönjük üzenetét! Hamarosan felvesszük Önnel a kapcsolatot.');
            this.reset();
        });

        // Map modal functionality
        function openMap(region) {
            const modal = document.getElementById('mapModal');
            const modalTitle = document.getElementById('modalTitle');
            const modalMap = document.getElementById('modalMap');
            const modalDescription = document.getElementById('modalDescription');
            
            // Set content based on region
            switch(region) {
                case 'budapest':
                    modalTitle.textContent = 'Budapest térképe';
                    modalMap.src = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d172139.4161676448!2d18.921100477203!3d47.481361644356!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4741c334d1d4cfc9%3A0x400c4290c1e1160!2sBudapest!5e0!3m2!1shu!2shu!4v1694300000000!5m2!1shu!2shu';
                    modalDescription.textContent = 'Budapest, Magyarország fővárosa, a Duna két partján fekszik. Gazdag gasztronómiai kultúrával rendelkezik, ahol a hagyományos magyar ételek találkoznak a modern konyhaművészettel.';
                    break;
                case 'eger':
                    modalTitle.textContent = 'Eger térképe';
                    modalMap.src = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2698.965448675195!2d21.402740815598842!3d48.10482507922516!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4738ac26cb62a66d%3A0x8786533afa289efd!2sEger%2C%20Hungary!5e0!3m2!1sen!2sus!4v1707786987789!5m2!1sen!2sus';
                    modalDescription.textContent = 'Eger Magyarország egyik legszebb barokk városa, híres a történelmi múltjáról és a bikavér boráról. A város a Bükk-vidék lábánál fekszik, és gazdag kulturális örökséggel rendelkezik.';
                    break;
                case 'balaton':
                    modalTitle.textContent = 'Balaton térképe';
                    modalMap.src = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d27105.856967649548!2d17.78418532089908!3d46.84583971535275!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x476d80b4f2d8c1ab%3A0x400f3e3b80b8360!2sBalaton%2C%20Hungary!5e0!3m2!1sen!2sus!4v1707787541234!5m2!1sen!2sus';
                    modalDescription.textContent = 'A Balaton, Közép-Európa legnagyobb tava, nyaralók és gasztronómiai élmények paradicsoma. A térség híres halételeiről és borairól. A Balaton-felvidék borvidéke minőségi fehérborairól ismert.';
                    break;
                case 'szeged':
                    modalTitle.textContent = 'Szeged térképe';
                    modalMap.src = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2696.375045593563!2d20.13819371560125!3d46.25301077911347!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4740e3dfd0f4d5d1%3A0xc2934a1c0d7e3f9e!2sSzeged%2C%20Hungary!5e0!3m2!1sen!2sus!4v1707787598765!5m2!1sen!2sus';
                    modalDescription.textContent = 'Szeged, a napfény városa, Magyarország harmadik legnagyobb városa. Híres a szegedi paprika, a halászlé és a nyári szabadtéri játékokról. A város a Tisza partján fekszik, és gazdag kulturális élettel rendelkezik.';
                    break;
            }
            
            modal.style.display = 'flex';
        }
        
        function closeMap() {
            document.getElementById('mapModal').style.display = 'none';
        }
        
        // Close modal when clicking outside of it
        window.addEventListener('click', function(event) {
            const modal = document.getElementById('mapModal');
            if (event.target === modal) {
                closeMap();
            }
        });
    </script>
